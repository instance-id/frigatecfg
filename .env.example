# Override config directory for local development.
# On server: defaults to ../config (parent frigate dir).
# Locally: set to ./config if you have a local config dir.
FRIGATE_CONFIG_DIR=./config

# Stored credentials - loaded on app startup, read-only in UI.
# Pattern: CREDENTIAL_USERNAME_<NAME> / CREDENTIAL_PASSWORD_<NAME>
# <NAME> underscores become hyphens in display name (e.g. REOLINK_1 → reolink-1)
# CREDENTIAL_USERNAME_REOLINK_1="frigate"
# CREDENTIAL_PASSWORD_REOLINK_1="supersecret"
# CREDENTIAL_USERNAME_OKAM="admin"
# CREDENTIAL_PASSWORD_OKAM="88888888"
